---
import "../../styles/article-introduction.css";
import {
  ARTICLE_LANG_LABELS,
  ARTICLE_LANGUAGES,
  ARTICLE_PAGE_KEYWORDS,
  ARTICLE_PAGE_TRANSLATIONS,
  ARTICLE_SHELL_TRANSLATIONS,
} from "../../data/articleI18n";
import { ARTICLE_BODY_TRANSLATIONS } from "../../data/articleBodyI18n";

const i18nPayload = JSON.stringify({
  languages: ARTICLE_LANGUAGES,
  labels: ARTICLE_LANG_LABELS,
  shell: ARTICLE_SHELL_TRANSLATIONS,
  pages: ARTICLE_PAGE_TRANSLATIONS,
  pageKey: "flex-rail-map-introduction",
});
const meta = ARTICLE_PAGE_TRANSLATIONS["flex-rail-map-introduction"].ja;
const bodyTranslations = ARTICLE_BODY_TRANSLATIONS["flex-rail-map-introduction"];
const keywords = ARTICLE_PAGE_KEYWORDS["flex-rail-map-introduction"];
---

<!DOCTYPE html>
<html lang="ja" data-theme="dark">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{meta.title} | Flex Rail Map</title>
  <meta name="description" content={meta.description} />
  <meta name="keywords" content={keywords} />
  <meta name="theme-color" content="#4CAF50" />
  <meta property="og:title" content={meta.title} />
  <meta property="og:type" content="article" />

  <script is:inline>
    (function(){
      try {
        var saved = localStorage.getItem('frm-theme');
        if (saved === 'light' || saved === 'dark') {
          document.documentElement.setAttribute('data-theme', saved);
        }
      } catch (e) {}
    })();
  </script>
  <script is:inline set:html={`window.__ARTICLE_I18N__=${i18nPayload};`}></script>

</head>
<body>

  <div class="masthead">
    <div class="row">
      <a href="/" class="brand"><span class="mk"></span><span data-i18n="brand">フレックス路線図</span></a>
      <div class="mh-actions">
        <span class="tagpill" data-i18n-page="tag">{meta.tag}</span>
        <button class="lang-btn" id="langBtn" aria-label="言語を切り替え" title="言語を切り替え">En</button>
        <button class="theme-btn" id="themeBtn" aria-label="ダークモード切り替え">
          <svg class="moon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.8A9 9 0 1 1 11.2 3a7 7 0 0 0 9.8 9.8z"/></svg>
          <svg class="sun" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="4"/><path d="M12 2v2M12 20v2M4.9 4.9l1.4 1.4M17.7 17.7l1.4 1.4M2 12h2M20 12h2M4.9 19.1l1.4-1.4M17.7 6.3l1.4-1.4"/></svg>
        </button>
      </div>
    </div>
  </div>

  <div class="wrap">
    <nav class="crumb"><a href="/" data-i18n="top">← フレックス路線図 トップ</a> ／ <a href="/articles" data-i18n="articles">記事一覧</a></nav>

    <header class="post">
      <span class="kicker" data-i18n-page="kicker">{meta.kicker}</span>
      <h1 data-i18n-page="title">{meta.title}</h1>
      <p class="lede" data-i18n-page="description">{meta.description}</p>
      <div class="byline">
        <span>2025年6月6日</span><span class="sep">／</span><span data-i18n-page="category">{meta.category}</span><span class="sep">／</span><span data-i18n-page="readTime">{meta.readTime}</span>
      </div>
    </header>

    <!-- ================= HERO DEMO ================= -->
    <section class="demo" aria-label="必要な路線だけ表示するデモ">
      <div class="demo-top">
        <div class="demo-ey" data-intro-demo="ey">まずは触ってみてください</div>
        <p class="demo-q" data-intro-demo="question">路線が全部出ていると、どこを見ればいいか分かりにくい。<br />でも——必要な路線だけにすると？</p>
        <p class="demo-hint" data-intro-demo="hint">下のボタンを切り替えると、表示する路線が変わります。情報を「減らす」だけで、どれだけ見やすくなるかを体験してみてください。</p>
      </div>
      <div class="seg" role="tablist" aria-label="表示モード">
        <button id="modeAll" role="tab" aria-selected="true"><span data-intro-demo="all">ぜんぶ表示</span> <span class="n" id="nAll">（20）</span></button>
        <button id="modeClean" role="tab" aria-selected="false"><span data-intro-demo="clean">必要な路線だけ</span> <span class="n">（3）</span></button>
      </div>
      <div class="stage-wrap" id="stage">
        <svg id="map" viewBox="0 0 720 480" role="img" aria-label="東京の路線を簡略化した概念図"></svg>
      </div>
      <div class="readout">
        <span class="countpill"><span class="big" id="cnt">20</span><span data-intro-demo="showing">路線を表示中</span></span>
        <span class="arrow" id="arrowTxt" data-intro-demo="arrow">← ボタンで「必要な路線だけ」に絞れます</span>
      </div>
      <div class="demo-note" data-intro-demo="note">※ これは仕組みを伝えるための概念図です。実際の駅の位置・路線の形・接続とは異なります。色は各路線のイメージに合わせた参考値です。</div>
    </section>
    <p class="figcap" data-intro-demo="caption">体験デモ：表示する路線を絞り込むと、ごちゃごちゃした路線図が「自分のための地図」に変わる。</p>
    <article>
      <div class="article-body-variants">
        {ARTICLE_LANGUAGES.map((lang) => bodyTranslations?.[lang] && (
          <div data-article-body={lang} hidden={lang !== "ja"} set:html={bodyTranslations[lang]} />
        ))}
      </div>
    </article>

    <div class="foot">
      <a href="/" data-i18n="top">← フレックス路線図 トップへ</a> ／ <a href="/articles" data-i18n="articlesBack">記事一覧へ戻る</a>
      <div class="small" data-i18n="footerCopy">フレックス路線図 ／ 東京の鉄道を、必要な情報だけで。</div>
    </div>
  </div>

  <script>
    /* ---------- theme ---------- */
    (function(){
      var root=document.documentElement, btn=document.getElementById('themeBtn');
      var saved=localStorage.getItem('frm-theme');
      if(saved){ root.setAttribute('data-theme',saved); }
      btn.addEventListener('click',function(){
        var next=root.getAttribute('data-theme')==='dark'?'light':'dark';
        root.setAttribute('data-theme',next); localStorage.setItem('frm-theme',next);
      });
    })();

    /* ---------- article language ---------- */
    (function(){
      var data = window.__ARTICLE_I18N__;
      if (!data) return;
      var languages = data.languages || ['ja', 'en', 'zh', 'ko'];
      var labelMap = data.labels || { ja: '日', en: 'En', zh: '中', ko: '한' };
      var pageKey = data.pageKey || 'flex-rail-map-introduction';
      var root = document.documentElement;
      var btn = document.getElementById('langBtn');
      var introDemoTexts = {
        ja: {
          ey: 'まずは触ってみてください',
          question: '路線が全部出ていると、どこを見ればいいか分かりにくい。<br />でも——必要な路線だけにすると？',
          hint: '下のボタンを切り替えると、表示する路線が変わります。情報を「減らす」だけで、どれだけ見やすくなるかを体験してみてください。',
          all: 'ぜんぶ表示',
          clean: '必要な路線だけ',
          showing: '路線を表示中',
          arrow: '← ボタンで「必要な路線だけ」に絞れます',
          arrowClean: '必要な3路線だけ。ぐっと見やすくなりました ✓',
          note: '※ これは仕組みを伝えるための概念図です。実際の駅の位置・路線の形・接続とは異なります。色は各路線のイメージに合わせた参考値です。',
          caption: '体験デモ：表示する路線を絞り込むと、ごちゃごちゃした路線図が「自分のための地図」に変わる。'
        },
        en: {
          ey: 'Try it first',
          question: 'When every line is visible, it is hard to know where to look.<br />But what if only the necessary lines remain?',
          hint: 'Use the buttons below to switch the visible lines and feel how reducing information makes the map easier to read.',
          all: 'Show all',
          clean: 'Needed lines only',
          showing: 'lines shown',
          arrow: '← Use the button to narrow the map to only the needed lines',
          arrowClean: 'Only 3 needed lines remain. Much easier to read ✓',
          note: 'This is a conceptual diagram for explaining the idea. Actual station positions, line shapes, and connections differ.',
          caption: 'Demo: filtering visible lines turns a crowded map into a map for your own trip.'
        },
        zh: {
          ey: '先试试看',
          question: '所有线路都显示时，很难知道该看哪里。<br />如果只留下需要的线路呢？',
          hint: '切换下面的按钮即可改变显示线路。试试看减少信息后路线图会变得多容易读。',
          all: '全部显示',
          clean: '只显示需要线路',
          showing: '条线路显示中',
          arrow: '← 使用按钮只保留需要的线路',
          arrowClean: '只剩 3 条需要的线路，清楚多了 ✓',
          note: '※ 这是用于说明机制的概念图。实际车站位置、线路形状和连接关系会有所不同。',
          caption: '体验演示：筛选显示线路后，拥挤的路线图会变成适合自己的地图。'
        },
        ko: {
          ey: '먼저 사용해 보세요',
          question: '모든 노선이 보이면 어디를 봐야 할지 어렵습니다.<br />그런데 필요한 노선만 남기면 어떨까요?',
          hint: '아래 버튼을 바꾸면 표시되는 노선이 달라집니다. 정보를 줄이는 것만으로 얼마나 읽기 쉬워지는지 확인해 보세요.',
          all: '전체 표시',
          clean: '필요한 노선만',
          showing: '개 노선 표시 중',
          arrow: '← 버튼으로 필요한 노선만 남길 수 있습니다',
          arrowClean: '필요한 3개 노선만 남았습니다. 훨씬 읽기 쉬워졌습니다 ✓',
          note: '※ 작동 방식을 설명하기 위한 개념도입니다. 실제 역 위치, 노선 형태, 연결과는 다릅니다.',
          caption: '체험 데모: 표시 노선을 줄이면 복잡한 노선도가 내 이동을 위한 지도로 바뀝니다.'
        }
      };
      window.__INTRO_DEMO__ = { texts: introDemoTexts, current: 'ja' };

      function normalize(value) {
        if (!value) return null;
        var lang = String(value).toLowerCase();
        if (lang === 'japanese') return 'ja';
        if (lang === 'english') return 'en';
        if (lang === 'chinese') return 'zh';
        if (lang === 'korean') return 'ko';
        return languages.indexOf(lang) >= 0 ? lang : null;
      }

      function nextLang(lang) {
        var index = languages.indexOf(lang);
        return languages[(index + 1) % languages.length] || 'ja';
      }

      function applyArticleBody(lang) {
        var hasLang = false;
        document.querySelectorAll('[data-article-body]').forEach(function(body) {
          var active = body.getAttribute('data-article-body') === lang;
          if (active) hasLang = true;
          body.hidden = !active;
        });
        if (!hasLang && lang !== 'ja') applyArticleBody('ja');
      }

      function applyIntroDemo(lang) {
        var texts = introDemoTexts[lang] || introDemoTexts.ja;
        window.__INTRO_DEMO__.current = lang;
        document.querySelectorAll('[data-intro-demo]').forEach(function(el) {
          var key = el.getAttribute('data-intro-demo');
          if (texts[key]) el.innerHTML = texts[key];
        });
      }

      function apply(lang) {
        var shell = data.shell && data.shell[lang] ? data.shell[lang] : data.shell.ja;
        var page = data.pages && data.pages[pageKey] && data.pages[pageKey][lang]
          ? data.pages[pageKey][lang]
          : null;
        root.setAttribute('lang', lang);
        document.querySelectorAll('[data-i18n]').forEach(function(el) {
          var key = el.getAttribute('data-i18n');
          if (shell && shell[key]) el.textContent = shell[key];
        });
        if (page) {
          document.querySelectorAll('[data-i18n-page]').forEach(function(el) {
            var key = el.getAttribute('data-i18n-page');
            if (page[key]) el.textContent = page[key];
          });
          document.title = page.title + ' | Flex Rail Map';
          var desc = document.querySelector('meta[name="description"]');
          if (desc && page.description) desc.setAttribute('content', page.description);
        }
        applyArticleBody(lang);
        applyIntroDemo(lang);
        if (btn) {
          var next = nextLang(lang);
          btn.textContent = labelMap[next] || next;
          btn.setAttribute('aria-label', shell.switchLanguage || 'Switch language');
          btn.setAttribute('title', shell.switchLanguage || 'Switch language');
          btn.setAttribute('data-current-lang', lang);
        }
        try {
          localStorage.setItem('frm-language', { ja: 'japanese', en: 'english', zh: 'chinese', ko: 'korean' }[lang] || lang);
          localStorage.setItem('frm-article-lang', lang);
        } catch (e) {}
      }

      var params = new URLSearchParams(window.location.search);
      var initial = normalize(params.get('lang'));
      if (!initial) {
        try {
          initial = normalize(localStorage.getItem('frm-language')) || normalize(localStorage.getItem('frm-article-lang'));
        } catch (e) {}
      }
      apply(initial || 'ja');
      if (btn) {
        btn.addEventListener('click', function() {
          var current = btn.getAttribute('data-current-lang') || 'ja';
          var next = nextLang(current);
          var url = new URL(window.location.href);
          if (next === 'ja') url.searchParams.delete('lang');
          else url.searchParams.set('lang', next);
          window.history.replaceState({}, '', url);
          apply(next);
        });
      }
    })();

    /* ---------- route map ---------- */
    (function(){
      // essential lines have stations[]; others are plain polylines.
      var LINES=[
        {k:'yamanote',ess:true,c:'#8FC542',w:7,p:'235,110 480,135 545,255 430,420 235,395 165,250 235,110',
          st:[['池袋',235,110,'m',-15],['上野',480,135,'s',-4],['東京',545,255,'s',4],['品川',430,420,'s',16],['渋谷',235,395,'e',17],['新宿',165,250,'e',-6]]},
        {k:'chuo',ess:true,c:'#F26B38',w:6,p:'60,215 165,250 300,238 445,212 545,255',
          st:[['中野',60,215,'e',-7],['四ツ谷',300,238,'m',18],['御茶ノ水',445,212,'m',-9]]},
        {k:'marunouchi',ess:true,c:'#E13B30',w:6,p:'235,110 370,165 500,235 545,255 520,305 390,295 165,250',
          st:[['後楽園',370,165,'m',-9],['大手町',500,235,'s',-6],['銀座',520,305,'s',6]]},
        {k:'sobu',c:'#F4C430',w:5,p:'60,215 165,250 350,200 470,195 620,200'},
        {k:'keihin',c:'#27A3E0',w:5,p:'430,110 480,135 470,195 545,255 430,420 480,470'},
        {k:'hibiya',c:'#9AA3A2',w:5,p:'250,430 350,340 520,305 470,195 480,135 575,95'},
        {k:'ginza',c:'#F59A23',w:5,p:'235,395 270,360 390,295 520,305 480,135 600,150'},
        {k:'tozai',c:'#13A7CE',w:5,p:'60,215 350,200 500,235 660,235'},
        {k:'chiyoda',c:'#2B9A57',w:5,p:'120,305 270,360 390,290 500,235 575,95'},
        {k:'hanzomon',c:'#8C76CC',w:5,p:'235,395 270,360 500,235 610,175'},
        {k:'yurakucho',c:'#C2A45E',w:5,p:'235,110 350,200 525,290 600,330'},
        {k:'namboku',c:'#15A99B',w:5,p:'320,430 350,340 390,295 370,165 430,110 360,60'},
        {k:'fukutoshin',c:'#9C6233',w:5,p:'235,110 195,265 235,395'},
        {k:'asakusa',c:'#E6587E',w:5,p:'430,420 480,320 520,305 610,175'},
        {k:'mita',c:'#1273BE',w:5,p:'320,430 470,360 500,235 330,90'},
        {k:'shinjukuline',c:'#7AB648',w:5,p:'165,250 350,210 445,225 660,210'},
        {k:'oedo',c:'#B23A8C',w:5,p:'165,250 350,340 490,345 560,210 370,170 245,150'},
        {k:'keio',c:'#D5247A',w:5,p:'165,250 90,290 20,300'},
        {k:'odakyu',c:'#1E7FC9',w:5,p:'165,250 110,320 40,360'},
        {k:'toyoko',c:'#D62246',w:5,p:'235,395 250,430 250,470 440,470'}
      ];
      var hubs=[[165,250],[235,395],[235,110],[545,255],[480,135],[430,420],[500,235],[350,200],[390,295],[350,340],[520,305],[250,430],[300,238],[370,165]];

      var NS='http://www.w3.org/2000/svg';
      var svg=document.getElementById('map');
      function el(n,a){var e=document.createElementNS(NS,n);for(var k in a)e.setAttribute(k,a[k]);return e;}

      var nonEssG=[], labels=[];   // refs we toggle

      // hub dots (shown only in 'all' mode)
      var gh=el('g',{}); hubs.forEach(function(h){ gh.appendChild(el('circle',{fill:'#9aa0a6','fill-opacity':'0.5',cx:h[0],cy:h[1],r:3.4})); });
      gh.style.transition='opacity .3s ease'; svg.appendChild(gh);

      // lines (non-ess first so ess draw on top)
      LINES.slice().sort(function(a,b){return (a.ess?1:0)-(b.ess?1:0);}).forEach(function(l){
        var g=el('g',{'data-k':l.k});
        g.style.transition='opacity .45s ease';
        g.appendChild(el('polyline',{points:l.p,fill:'none',stroke:l.c,'stroke-width':l.w,'stroke-linejoin':'round','stroke-linecap':'round'}));
        if(l.st){ l.st.forEach(function(s){
          g.appendChild(el('circle',{cx:s[1],cy:s[2],r:5,fill:'#ffffff',stroke:l.c,'stroke-width':2.4}));
          var anc=s[3]==='e'?'end':(s[3]==='m'?'middle':'start');
          var dx=s[3]==='e'?-9:(s[3]==='m'?0:9);
          var t=el('text',{'class':'rlabel',x:s[1]+dx,y:s[2]+(s[4]||0),'text-anchor':anc});
          t.style.transition='opacity .4s ease'; t.style.opacity='0';
          t.textContent=s[0]; g.appendChild(t); labels.push(t);
        });}
        if(!l.ess) nonEssG.push(g);
        svg.appendChild(g);
      });

      document.getElementById('nAll').textContent='（'+LINES.length+'）';

      var cnt=document.getElementById('cnt');
      var bAll=document.getElementById('modeAll'), bClean=document.getElementById('modeClean');
      var arrow=document.getElementById('arrowTxt');
      var essN=LINES.filter(function(l){return l.ess;}).length;

      function set(clean){
        var demo = window.__INTRO_DEMO__ || {};
        var texts = (demo.texts && demo.texts[demo.current]) || (demo.texts && demo.texts.ja) || {};
        nonEssG.forEach(function(g){ g.style.opacity=clean?'0':'1'; });
        labels.forEach(function(t){ t.style.opacity=clean?'1':'0'; });
        gh.style.opacity=clean?'0':'1';
        if(bAll) bAll.setAttribute('aria-selected',clean?'false':'true');
        if(bClean) bClean.setAttribute('aria-selected',clean?'true':'false');
        if(cnt) cnt.textContent=clean?essN:LINES.length;
        if(arrow) arrow.textContent=clean?(texts.arrowClean || '必要な3路線だけ。ぐっと見やすくなりました ✓'):(texts.arrow || '← ボタンで「必要な路線だけ」に絞れます');
      }
      bAll.addEventListener('click',function(){set(false);});
      bClean.addEventListener('click',function(){set(true);});
      set(false);
    })();
  </script>

</body>
</html>
