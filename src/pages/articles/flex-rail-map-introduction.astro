  <meta name="keywords" content="フレックス路線図, 路線図 見にくい, 路線図 複雑, 必要な路線だけ, インタラクティブ路線図, 乗り換え 分かりやすい" />
  <meta name="theme-color" content="#4CAF50" />
  <meta property="og:title" content="東京の路線図を「理解しやすく」する路線図UIを作っています" />
  <meta property="og:type" content="article" />

  <script is:inline>
    (function(){
      try {
        var saved = localStorage.getItem('frm-theme');
        if (saved === 'light' || saved === 'dark') {
          document.documentElement.setAttribute('data-theme', saved);
        }
      } catch (e) {}
    })();
  </script>

</head>
<body>

  <div class="masthead">
    <div class="row">
      <a href="/" class="brand"><span class="mk"></span>フレックス路線図</a>
      <div class="mh-actions">
        <span class="tagpill">Dev Notes</span>
        <button class="theme-btn" id="themeBtn" aria-label="ダークモード切り替え">
