---
import "../../styles/article-layout.css";
import {
  ARTICLE_LANG_LABELS,
  ARTICLE_LANGUAGES,
  ARTICLE_PAGE_TRANSLATIONS,
  ARTICLE_SHELL_TRANSLATIONS,
} from "../../data/articleI18n";

export interface Props {
  title: string;
  description: string;
  keywords?: string;
  slug: string;
  category: string;
  kicker?: string;
  publishedDate?: string;
  readTime?: string;
  tag?: string;
  ogImage?: string;
  canonicalPath?: string;
  kind?: "article" | "index";
}

const {
  title,
  description,
  keywords,
  slug,
  category,
  kicker = "Rail Guide",
  publishedDate = "2025-06-06",
  readTime = "読了 約4分",
  tag = "Article",
  ogImage = "/icon_flex_rail_way_map.png",
  canonicalPath,
  kind = "article",
} = Astro.props;

const siteUrl = "https://flex-railway-map.netlify.app";
const canonicalUrl = `${siteUrl}${canonicalPath ?? `/articles/${slug}`}`;
const displayDate = publishedDate.replace(/^(\d{4})-(\d{2})-(\d{2})$/, "$1年$2月$3日");
const isArticle = kind === "article";
const i18nKey = kind === "index" ? "articles" : slug;
const i18nPayload = JSON.stringify({
  languages: ARTICLE_LANGUAGES,
  labels: ARTICLE_LANG_LABELS,
  shell: ARTICLE_SHELL_TRANSLATIONS,
  pages: ARTICLE_PAGE_TRANSLATIONS,
  pageKey: i18nKey,
});
---

<!DOCTYPE html>
<html lang="ja" data-theme="dark">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title data-i18n-title>{title} | Flex Rail Map</title>
  <meta name="description" content={description} data-i18n-description />
  {keywords && <meta name="keywords" content={keywords} />}
  <meta name="theme-color" content="#13171A" />
  <link rel="canonical" href={canonicalUrl} />

  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content={isArticle ? "article" : "website"} />
  <meta property="og:url" content={canonicalUrl} />
  <meta property="og:image" content={`${siteUrl}${ogImage}`} />
  <meta name="twitter:card" content="summary" />

  <meta name="google-site-verification" content="uyjBT9z6vOnpxn6lM6YnxbI6R4jLSDIAboC8zo1slhM" />
  <meta name="google-adsense-account" content="ca-pub-2444529114040977" />
  <script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-2444529114040977" crossorigin="anonymous"></script>

  <link rel="icon" type="image/png" sizes="32x32" href="/icon_flex_rail_way_map.png" />
  <script is:inline>
    (function(){
      try {
        var saved = localStorage.getItem('frm-theme');
        if (saved === 'light' || saved === 'dark') {
          document.documentElement.setAttribute('data-theme', saved);
        }
      } catch (e) {}
    })();
  </script>

  <script is:inline set:html={`window.__ARTICLE_I18N__=${i18nPayload};`}></script>

  {isArticle && <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": title,
    "description": description,
    "datePublished": publishedDate,
    "dateModified": publishedDate,
    "author": { "@type": "Organization", "name": "Flex Rail Map Project" },
    "publisher": {
      "@type": "Organization",
      "name": "Flex Rail Map Project",
      "logo": { "@type": "ImageObject", "url": `${siteUrl}${ogImage}` }
    }
  })}></script>}

  <slot name="head" />
</head>
<body>
  <div class="masthead">
    <div class="row">
      <a href="/" class="brand"><span class="mk"></span><span data-i18n="brand">フレックス路線図</span></a>
      <div class="mh-actions">
        <span class="tagpill" data-i18n-page="tag">{tag}</span>
        <button class="lang-btn" id="langBtn" aria-label="言語を切り替え" title="言語を切り替え">En</button>
        <button class="theme-btn" id="themeBtn" aria-label="ダークモード切り替え">
          <svg class="moon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.8A9 9 0 1 1 11.2 3a7 7 0 0 0 9.8 9.8z"/></svg>
          <svg class="sun" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="4"/><path d="M12 2v2M12 20v2M4.9 4.9l1.4 1.4M17.7 17.7l1.4 1.4M2 12h2M20 12h2M4.9 19.1l1.4-1.4M17.7 6.3l1.4-1.4"/></svg>
        </button>
      </div>
    </div>
  </div>

  <div class="wrap">
    <nav class="crumb"><a href="/" data-i18n="top">← フレックス路線図 トップ</a> ／ <a href="/articles" data-i18n="articles">記事一覧</a></nav>
    <header class="post">
      <span class="kicker" data-i18n-page="kicker">{kicker}</span>
      <h1 data-i18n-page="title">{title}</h1>
      <p class="lede" data-i18n-page="description">{description}</p>
      <div class="byline">
        <span>{displayDate}</span><span class="sep">／</span><span data-i18n-page="category">{category}</span><span class="sep">／</span><span data-i18n-page="readTime">{readTime}</span>
      </div>
    </header>
    <slot name="beforeArticle" />
    <article>
      <slot />
    </article>
    <div class="foot">
      <a href="/" data-i18n="top">← フレックス路線図 トップへ</a> ／ <a href="/articles" data-i18n="articlesBack">記事一覧へ戻る</a>
      <div class="small" data-i18n="footerCopy">フレックス路線図 ／ 東京の鉄道を、必要な情報だけで。</div>
    </div>
  </div>

  <script is:inline>
    (function(){
      var root = document.documentElement;
      var btn = document.getElementById('themeBtn');
      if (!btn) return;
      btn.addEventListener('click', function(){
        var next = root.getAttribute('data-theme') === 'dark' ? 'light' : 'dark';
        root.setAttribute('data-theme', next);
        try { localStorage.setItem('frm-theme', next); } catch (e) {}
      });
    })();
  </script>
  <script is:inline>
    (function(){
      var data = window.__ARTICLE_I18N__;
      if (!data) return;
      var languages = data.languages || ['ja', 'en', 'zh', 'ko'];
      var labelMap = data.labels || { ja: '日', en: 'En', zh: '中', ko: '한' };
      var pageKey = data.pageKey || 'articles';
      var root = document.documentElement;
      var btn = document.getElementById('langBtn');

      function normalize(value) {
        if (!value) return null;
        var lang = String(value).toLowerCase();
        if (lang === 'japanese') return 'ja';
        if (lang === 'english') return 'en';
        if (lang === 'chinese') return 'zh';
        if (lang === 'korean') return 'ko';
        return languages.indexOf(lang) >= 0 ? lang : null;
      }

      function nextLang(lang) {
        var index = languages.indexOf(lang);
        return languages[(index + 1) % languages.length] || 'ja';
      }

      function applyArticleCards(lang) {
        document.querySelectorAll('[data-article-card]').forEach(function(card) {
          var key = card.getAttribute('data-article-card');
          var page = data.pages && data.pages[key] && data.pages[key][lang];
          if (!page) return;
          var title = card.querySelector('[data-article-title]');
          var meta = card.querySelector('[data-article-meta]');
          if (title) title.textContent = page.title;
          if (meta) meta.textContent = page.category;
        });
      }

      function apply(lang) {
        var shell = data.shell && data.shell[lang] ? data.shell[lang] : data.shell.ja;
        var page = data.pages && data.pages[pageKey] && data.pages[pageKey][lang]
          ? data.pages[pageKey][lang]
          : null;
        root.setAttribute('lang', lang);
        document.querySelectorAll('[data-i18n]').forEach(function(el) {
          var key = el.getAttribute('data-i18n');
          if (shell && shell[key]) el.textContent = shell[key];
        });
        if (page) {
          document.querySelectorAll('[data-i18n-page]').forEach(function(el) {
            var key = el.getAttribute('data-i18n-page');
            if (page[key]) el.textContent = page[key];
          });
          document.title = page.title + ' | Flex Rail Map';
          var desc = document.querySelector('meta[name="description"]');
          if (desc && page.description) desc.setAttribute('content', page.description);
        }
        applyArticleCards(lang);
        if (btn) {
          var next = nextLang(lang);
          btn.textContent = labelMap[next] || next;
          btn.setAttribute('aria-label', shell.switchLanguage || 'Switch language');
          btn.setAttribute('title', shell.switchLanguage || 'Switch language');
          btn.setAttribute('data-current-lang', lang);
        }
        try { localStorage.setItem('frm-article-lang', lang); } catch (e) {}
      }

      var params = new URLSearchParams(window.location.search);
      var initial = normalize(params.get('lang'));
      if (!initial) {
        try { initial = normalize(localStorage.getItem('frm-article-lang')); } catch (e) {}
      }
      apply(initial || 'ja');
      if (btn) {
        btn.addEventListener('click', function() {
          var current = btn.getAttribute('data-current-lang') || 'ja';
          var next = nextLang(current);
          var url = new URL(window.location.href);
          if (next === 'ja') url.searchParams.delete('lang');
          else url.searchParams.set('lang', next);
          window.history.replaceState({}, '', url);
          apply(next);
        });
      }
    })();
  </script>
  <slot name="scripts" />
</body>
</html>
