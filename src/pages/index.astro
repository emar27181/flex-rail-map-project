---
import RailwayMap from '../components/RailwayMap.tsx';
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>路線図アプリ</title>
		<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"
		  integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY="
		  crossorigin=""/>
		<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"
		  integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo="
		  crossorigin=""></script>
		<style>
			body {
				margin: 0;
				padding: 20px;
				font-family: Arial, sans-serif;
			}
			.leaflet-container {
				height: 600px !important;
				width: 100% !important;
			}
		</style>
	</head>
	<body>
		<h1>東京路線図</h1>
		<RailwayMap client:only="react" />

		<footer style="margin-top: 40px; padding: 20px; background-color: #f8f9fa; border-top: 1px solid #e9ecef; font-size: 14px; color: #6c757d;">
			<div style="max-width: 800px; margin: 0 auto;">
				<p style="margin: 0 0 10px 0; font-weight: bold;">© 2025 Flex Rail Map Project</p>
				<p style="margin: 0 0 5px 0;">駅データは独自作成またはオープンデータを利用しています。</p>
				<p style="margin: 0 0 5px 0;">本サービスは非公式であり、各鉄道事業者とは関係ありません。</p>
				<p style="margin: 0 0 10px 0;">提供する情報は目安です。正確な運行情報は公式サイトをご確認ください。</p>
				<p style="margin: 0; font-size: 12px;">Made with <a href="https://claude.ai/code" target="_blank" style="color: #007bff; text-decoration: none;">Claude Code</a></p>
			</div>
		</footer>
	</body>
</html>
