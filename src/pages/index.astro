---
import ThemeWrapper from '../components/ThemeWrapper.tsx';
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>東京フレックス路線図 - Tokyo Flex Railway Map</title>
		<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"
		  integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY="
		  crossorigin=""/>
		<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"
		  integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo="
		  crossorigin=""></script>
		<style>
			body {
				margin: 0;
				padding: 0;
				font-family: Arial, sans-serif;
				transition: background-color 0.3s ease, color 0.3s ease;
			}
			body.light {
				background-color: #ffffff;
				color: #333333;
			}
			body.dark {
				background-color: #1a1a1a;
				color: #ffffff;
			}
			body.dark h1 {
				color: #ffffff;
			}
			body.dark footer {
				background-color: #2d2d2d !important;
				border-top-color: #404040 !important;
				color: #b3b3b3 !important;
			}
			.leaflet-container {
				height: 600px !important;
				width: 100% !important;
			}

			/* Dark mode support for Leaflet popups - Complete coverage */
			body.dark .leaflet-popup {
				background-color: #2d2d2d !important;
			}

			body.dark .leaflet-popup-content-wrapper {
				background-color: #2d2d2d !important;
				color: #ffffff !important;
				box-shadow: 0 3px 14px rgba(0,0,0,0.8) !important;
				border: 1px solid #404040 !important;
			}

			body.dark .leaflet-popup-content {
				background-color: #2d2d2d !important;
				color: #ffffff !important;
				margin: 0 !important;
			}

			body.dark .leaflet-popup-tip {
				background-color: #2d2d2d !important;
				border: 1px solid #404040 !important;
				box-shadow: none !important;
			}

			body.dark .leaflet-popup-tip-container {
				background-color: #2d2d2d !important;
			}

			body.dark .leaflet-popup-close-button {
				color: #ffffff !important;
				background-color: transparent !important;
			}

			body.dark .leaflet-popup-close-button:hover {
				color: #cccccc !important;
				background-color: rgba(255,255,255,0.1) !important;
			}

			/* Force all nested elements to inherit dark mode styling */
			body.dark .leaflet-popup *,
			body.dark .leaflet-popup div,
			body.dark .leaflet-popup span,
			body.dark .leaflet-popup strong,
			body.dark .leaflet-popup p {
				color: #ffffff !important;
				background-color: transparent !important;
			}

			/* Override any inline styles that might be preventing dark mode */
			body.dark .leaflet-popup [style*="background"] {
				background-color: #2d2d2d !important;
			}

			body.dark .leaflet-popup [style*="color"] {
				color: #ffffff !important;
			}
		</style>
	</head>
	<body>
		<ThemeWrapper client:only="react" />
	</body>
</html>
