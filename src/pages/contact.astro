---
import SimpleThemeWrapper from "../components/SimpleThemeWrapper.tsx";
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<meta
			name="google-site-verification"
			content="uyjBT9z6vOnpxn6lM6YnxbI6R4jLSDIAboC8zo1slhM"
		/>
		<meta name="google-adsense-account" content="ca-pub-2444529114040977" />
		<link
			rel="icon"
			type="image/png"
			sizes="32x32"
			href="/icon_flex_rail_way_map.png"
		/>
		<link
			rel="icon"
			type="image/png"
			sizes="16x16"
			href="/icon_flex_rail_way_map.png"
		/>
		<link
			rel="apple-touch-icon"
			sizes="180x180"
			href="/icon_flex_rail_way_map.png"
		/>
		<link rel="shortcut icon" href="/icon_flex_rail_way_map.png" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>Contact - 東京フレックス路線図 / Tokyo Flex Railway Map</title>

		<!-- SEO Meta Description -->
		<meta name="description" content="お問い合わせ - 東京フレックス路線図へのご連絡はこちらから。Contact - Reach out to Tokyo Flex Railway Map team." />

		<!-- hreflang for multilingual SEO -->
		<link rel="alternate" hreflang="ja" href="https://flex-railway-map.netlify.app/contact?lang=ja" />
		<link rel="alternate" hreflang="en" href="https://flex-railway-map.netlify.app/contact?lang=en" />
		<link rel="alternate" hreflang="x-default" href="https://flex-railway-map.netlify.app/contact" />

		<style>
			body {
				margin: 0;
				padding: 0;
				font-family: Arial, sans-serif;
				transition:
					background-color 0.3s ease,
					color 0.3s ease;
			}
			body.light {
				background-color: #ffffff;
				color: #333333;
			}
			body.dark {
				background-color: #1a1a1a;
				color: #ffffff;
			}
			body.dark h1, body.dark h2, body.dark h3 {
				color: #ffffff;
			}
			body.dark footer {
				background-color: #2d2d2d !important;
				border-top-color: #404040 !important;
				color: #b3b3b3 !important;
			}
			.container {
				max-width: 800px;
				margin: 0 auto;
				padding: 20px;
				line-height: 1.6;
			}
			h2 {
				border-bottom: 2px solid #2196F3;
				padding-bottom: 8px;
				margin-bottom: 24px;
			}
			h3 {
				color: #2196F3;
				margin-top: 32px;
				margin-bottom: 12px;
			}
			ul {
				margin-left: 20px;
			}
			li {
				margin-bottom: 8px;
			}
			a {
				color: #2196F3;
				text-decoration: none;
			}
			a:hover {
				text-decoration: underline;
			}
			.back-link {
				display: inline-block;
				margin-bottom: 20px;
				padding: 8px 16px;
				background-color: #2196F3;
				color: white;
				border-radius: 4px;
				text-decoration: none;
			}
			.back-link:hover {
				background-color: #1976D2;
				text-decoration: none;
			}
			.contact-box {
				background-color: #f5f5f5;
				padding: 20px;
				border-radius: 8px;
				margin: 20px 0;
			}
			body.dark .contact-box {
				background-color: #2d2d2d;
				border: 1px solid #404040;
			}
		</style>
	</head>
	<body>
		<div class="container">
			<a href="/" class="back-link">← 路線図に戻る / Back to Map</a>

			<!-- Japanese Contact -->
			<div id="contact-ja">
				<h2>お問い合わせ</h2>

				<h3>ご連絡方法</h3>
				<p>
				Tokyo Flex Railway Map に関するお問い合わせは、以下の方法でご連絡ください。
				</p>

				<div class="contact-box">
					<h3 style="margin-top: 0;">GitHub Issues（推奨）</h3>
					<p>
					バグ報告、機能リクエスト、その他のご意見は GitHub Issues からお願いします。
					</p>
					<a href="https://github.com/emar27181" target="_blank" rel="noopener noreferrer">
						GitHub: emar27181
					</a>
				</div>

				<h3>お問い合わせ内容の例</h3>
				<ul>
				<li>バグ報告（表示がおかしい、エラーが発生する等）</li>
				<li>機能追加のリクエスト</li>
				<li>データの誤りの報告（駅の位置が間違っている等）</li>
				<li>その他のご意見・ご要望</li>
				</ul>

				<h3>返信について</h3>
				<p>
				お問い合わせいただいた内容は、できる限り迅速に対応させていただきますが、
				開発者の都合により返信にお時間をいただく場合がございます。あらかじめご了承ください。
				</p>

				<h3>広告・提携に関するお問い合わせ</h3>
				<p>
				広告掲載や提携に関するご相談は、GitHub プロフィール経由でご連絡ください。
				</p>
			</div>

			<!-- English Contact -->
			<div id="contact-en" style="display: none;">
				<h2>Contact</h2>

				<h3>How to Reach Us</h3>
				<p>
				For inquiries regarding Tokyo Flex Railway Map, please contact us through the following methods:
				</p>

				<div class="contact-box">
					<h3 style="margin-top: 0;">GitHub Issues (Recommended)</h3>
					<p>
					For bug reports, feature requests, or other feedback, please use GitHub Issues.
					</p>
					<a href="https://github.com/emar27181" target="_blank" rel="noopener noreferrer">
						GitHub: emar27181
					</a>
				</div>

				<h3>Types of Inquiries</h3>
				<ul>
				<li>Bug reports (display issues, errors, etc.)</li>
				<li>Feature requests</li>
				<li>Data error reports (incorrect station locations, etc.)</li>
				<li>Other comments and suggestions</li>
				</ul>

				<h3>Response Time</h3>
				<p>
				We will respond to your inquiries as quickly as possible, but please note that
				response times may vary depending on the developer's availability.
				</p>

				<h3>Advertising & Partnership Inquiries</h3>
				<p>
				For advertising or partnership opportunities, please contact us via GitHub profile.
				</p>
			</div>
		</div>

		<script>
			// Language detection and switching
			function switchLanguage() {
				const urlParams = new URLSearchParams(window.location.search);
				const lang = urlParams.get('lang') || 'ja'; // Default to Japanese

				const jaContent = document.getElementById('contact-ja');
				const enContent = document.getElementById('contact-en');

				if (lang === 'en') {
					jaContent.style.display = 'none';
					enContent.style.display = 'block';
				} else {
					jaContent.style.display = 'block';
					enContent.style.display = 'none';
				}
			}

			// Apply theme
			function applyTheme() {
				const savedTheme = localStorage.getItem('theme') || 'light';
				document.body.className = savedTheme;
			}

			// Initialize on page load
			document.addEventListener('DOMContentLoaded', () => {
				switchLanguage();
				applyTheme();
			});
		</script>

		<SimpleThemeWrapper client:only="react" />
	</body>
</html>
