---
import DiagramMap from "../components/DiagramMap.tsx";
---

<html lang="ja">
	<head>
		<meta charset="utf-8" />
		<link
			rel="icon"
			type="image/png"
			sizes="32x32"
			href="/icon_flex_rail_way_map.png"
		/>
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<meta name="generator" content={Astro.generator} />
		<title>路線図モード（実験的） - フレックス路線図</title>
		<meta name="robots" content="noindex" />
		<style>
			*, *::before, *::after {
				box-sizing: border-box;
			}
			html, body {
				margin: 0;
				padding: 0;
				width: 100%;
				height: 100%;
				overflow: hidden;
				font-family: Arial, sans-serif;
				background: #fff;
			}
			#root {
				width: 100%;
				height: 100%;
			}
			/* ヘッダー */
			#header {
				position: fixed;
				top: 0;
				left: 0;
				right: 0;
				height: 40px;
				background: #222;
				color: #fff;
				display: flex;
				align-items: center;
				justify-content: space-between;
				padding: 0 12px;
				z-index: 100;
				font-size: 13px;
			}
			#header a {
				color: #aaa;
				text-decoration: none;
				font-size: 12px;
			}
			#header a:hover {
				color: #fff;
			}
			#map-container {
				position: fixed;
				top: 40px;
				left: 0;
				right: 0;
				bottom: 0;
			}
		</style>
	</head>
	<body>
		<div id="header">
			<span>📊 路線図モード（実験的） — 線の重複を軽減したSVG路線図</span>
			<a href="/">← フレックス路線図に戻る</a>
		</div>
		<div id="map-container">
			<DiagramMap client:only="react" />
		</div>
	</body>
</html>
