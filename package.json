{
  "name": "astro-app",
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "dev": "astro dev --port 8080 --host",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "test": "vitest tests/unit",
    "test:ui": "vitest --ui tests/unit",
    "test:run": "vitest run tests/unit",
    "test:types": "tsc --project tsconfig.check.json",
    "test:unit": "vitest run tests/unit",
    "test:ci": "npm run test:types && npm run test:unit",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:prod": "TEST_URL=https://flex-railway-map.netlify.app playwright test",
    "deploy:preview": "npm run test:ci && netlify deploy --alias preview",
    "deploy:prod": "npm run test:ci && npm run test:e2e && netlify deploy --prod"
  },
  "dependencies": {
    "@astrojs/react": "^4.3.0",
    "@types/leaflet": "^1.9.20",
    "@types/react": "^19.1.12",
    "@types/react-dom": "^19.1.9",
    "astro": "^5.13.5",
    "leaflet": "^1.9.4",
    "leaflet.heat": "^0.2.0",
    "lucide-react": "^0.544.0",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "react-leaflet": "^5.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.9.1",
    "@vitejs/plugin-react": "^6.0.2",
    "jsdom": "^29.1.1",
    "vitest": "^2.1.0"
  }
}
